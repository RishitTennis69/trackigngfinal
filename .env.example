# Server
# In production, most hosts set PORT for you. Keep the fallback in code.
PORT=4173
HOST=
APP_BASE_URL=
MAX_CRAWL_PAGES=8
MAX_SCAN_PROMPTS=18

# Supabase database
# For the old local-storage-compatible setup, run supabase-schema.sql.
# For the shared landing-page + dashboard setup, run shared-supabase-schema.sql
# and set SUPABASE_PROJECT_MODE=shared.
# Standalone mode (default): clients sign up directly without the landing/payment app.
STANDALONE_MODE=true
STANDALONE_PREMIUM_INSIGHTS=false
# When false, only admins can create accounts via the admin dashboard.
PUBLIC_SIGNUP_ENABLED=false
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PROJECT_MODE=shared
ENTITLEMENT_ALLOWED_STATUSES=active,trialing
PREMIUM_ENTITLEMENT_PLANS=gleo-premium,gleo-reoptimization,tracking-premium

# OpenAI / ChatGPT scan provider
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-5-nano
OPENAI_USE_WEB_SEARCH=true

# Gemini via OpenRouter (uses OPENROUTER_API_KEY above)
GEMINI_OPENROUTER_MODEL=google/gemini-2.5-flash-lite

# OpenRouter / Claude scan provider
OPENROUTER_API_KEY=sk-or-your-openrouter-api-key
OPENROUTER_MODEL=anthropic/claude-haiku-4.5
OPENROUTER_USE_WEB_SEARCH=true
# Optional. Use your real deployed app URL in production if OpenRouter expects a referrer.
OPENROUTER_HTTP_REFERER=

# Optional premium SMS alerts
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=

# Optional admin dashboard auth
# The admin page does not exist at all unless these are configured.
ADMIN_DASHBOARD_PATH=quiet-copper-room
ADMIN_EMAIL=gleo.outreach@gmail.com
ADMIN_PASSWORD=change-this-admin-password
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret
